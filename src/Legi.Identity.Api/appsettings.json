{
  "Logging": {
    "Console": { "IncludeScopes": true },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "IdentityDb": "Host=localhost;Port=5432;Database=legi_identity;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "PublicKey": "",
    "PrivateKey": "",
    "Issuer": "Legi.Identity",
    "Audience": "Legi",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "LoginLockout": {
    "MaxFailedAttempts": 5,
    "FailureWindowMinutes": 15,
    "LockoutDurationMinutes": 15
  },
  "Turnstile": {
    "Enabled": false,
    "SecretKey": "",
    "SiteVerifyUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify",
    "AllowedHostnames": [ "localhost" ],
    "RequireForRegistration": true,
    "RequireForEmailConfirmation": true,
    "LoginFailedAttemptsBeforeRequired": 2,
    "VerificationTimeoutSeconds": 5
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "legi",
    "Password": "legi_dev",
    "ClientProvidedName": "legi-identity"
  },
  "Outbox": {
    "PollingIntervalMs": 1000,
    "BatchSize": 50,
    "MaxAttempts": 5
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/v1/identity/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/v1/identity/auth/mfa-login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/v1/identity/auth/register",
        "Period": "1h",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/v1/identity/auth/resend-confirmation",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/v1/identity/auth/refresh",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/v1/identity/mfa/disable",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/v1/identity/mfa/confirm",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": []
  }
}
