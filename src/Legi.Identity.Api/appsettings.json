{
  "Logging": {
    "Console": { "IncludeScopes": true },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "IdentityDb": "Host=localhost;Port=5432;Database=legi_identity;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "Legi.Identity",
    "Audience": "Legi",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "legi",
    "Password": "legi_dev",
    "ClientProvidedName": "legi-identity"
  },
  "Outbox": {
    "PollingIntervalMs": 1000,
    "BatchSize": 50,
    "MaxAttempts": 5
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/v1/identity/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/v1/identity/auth/register",
        "Period": "1h",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/v1/identity/auth/refresh",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": []
  }
}
