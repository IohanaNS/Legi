# .env.example - Copy this to .env and fill in your values
# The .env file is automatically loaded by DotNetEnv on application startup

# Database Configuration
ConnectionStrings__IdentityDb=Host=localhost;Port=5432;Database=legi_identity_dev;Username=postgres;Password=postgres
ConnectionStrings__CatalogDatabase=Host=localhost;Port=5433;Database=legi_catalog_dev;Username=postgres;Password=postgres
ConnectionStrings__LibraryDatabase=Host=localhost;Port=5434;Database=legi_library_dev;Username=postgres;Password=postgres
ConnectionStrings__SocialDatabase=Host=localhost;Port=5435;Database=legi_social_dev;Username=postgres;Password=postgres

# RabbitMq (local dev defaults are already in appsettings.Development.json; override here only if needed)
# RabbitMq__Host=localhost
# RabbitMq__Port=5672
# RabbitMq__Username=legi
# RabbitMq__Password=legi_dev

# JWT Configuration (REQUIRED) — RS256 asymmetric keys.
# No keys are committed. Generate a local dev keypair into your .env with:
#   ./scripts/gen-dev-keys.sh
# Identity signs with the private key; every service validates with the public key.
Jwt__PublicKey=
Jwt__PrivateKey=
Jwt__Issuer=Legi.Identity.Dev
Jwt__Audience=Legi.Dev
Jwt__AccessTokenExpirationMinutes=15
Jwt__RefreshTokenExpirationDays=7

# MFA (TOTP) — encrypts authenticator secrets at rest. Populated by ./scripts/gen-dev-keys.sh
Mfa__EncryptionKey=

# External book providers
# Optional but recommended to avoid low anonymous Google Books API limits.
# Keep this key server-side only; do not expose it in the frontend.
ExternalServices__GoogleBooks__Enabled=true
ExternalServices__GoogleBooks__ApiKey=YOUR_GOOGLE_BOOKS_API_KEY_HERE

# Password reset
# Public base URL of the web frontend, used to build the reset link emailed to users.
# REQUIRED in non-dev environments: set this to your real site URL (e.g. https://bukihub.com)
# or reset emails will link to localhost. There is intentionally no production default.
PasswordReset__FrontendBaseUrl=http://localhost:3000
PasswordReset__TokenLifetimeMinutes=60

# SMTP (email delivery for password resets). Leave Smtp__Host empty to log the reset
# link instead of sending email (handy for local development without a mail server).
# Smtp__Host=smtp.example.com
# Smtp__Port=587
# Smtp__Username=apikey
# Smtp__Password=YOUR_SMTP_PASSWORD
# Smtp__FromAddress=no-reply@bukihub.com
# Smtp__FromName=BukiHub
# Smtp__UseStartTls=true

# Google Sign-In (optional)
# Create an OAuth 2.0 "Web application" client at https://console.cloud.google.com/apis/credentials
# and add your origins (e.g. http://localhost:3000) to "Authorized JavaScript origins".
# The SAME client id must be set for both the backend (token validation) and the
# frontend (renders the Google button). Leave unset to disable Google sign-in.
# GoogleAuth__ClientId=id9gld.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=id9gld.apps.googleusercontent.com

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Development
