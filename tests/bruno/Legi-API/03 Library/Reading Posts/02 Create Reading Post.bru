meta {
  name: Create Reading Post
  type: http
  seq: 2
}

post {
  url: {{libraryBaseUrl}}/api/v1/library/{{userBookId}}/posts
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Accept: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "content": "Initial reading note from Bruno.",
    "progressValue": 42,
    "progressType": 0,
    "readingDate": "{{readingDate}}"
  }
}

script:post-response {
  const raw = res.getBody();
  let data = {};
  if (typeof raw === "string" && raw.length) data = JSON.parse(raw);
  else if (raw && raw.parsedBody) data = raw.parsedBody;
  else if (raw) data = raw;
  if (data.postId) bru.setEnvVar("postId", data.postId);
}
