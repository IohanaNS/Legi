meta {
  name: Update Reading Post
  type: http
  seq: 3
}

put {
  url: {{libraryBaseUrl}}/api/v1/library/posts/{{postId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Accept: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "content": "Updated reading note from Bruno.",
    "progressValue": 58,
    "progressType": 0
  }
}
