meta {
  name: Get My UserBook By Book
  type: http
  seq: 6
}

get {
  url: {{libraryBaseUrl}}/api/v1/library/by-book/{{bookId}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Returns the authenticated user's UserBook for a book (200) or 204 if the book
  is not in their library. Drives the book details page header. Chains after
  "User Books/03 Add Book To Library" so {{bookId}}/{{userBookId}} are set.
}

script:post-response {
  const raw = res.getBody();
  let data = {};
  if (typeof raw === "string" && raw.length) data = JSON.parse(raw);
  else if (raw && raw.parsedBody) data = raw.parsedBody;
  else if (raw) data = raw;
  if (data.userBookId) bru.setEnvVar("userBookId", data.userBookId);
}
