meta {
  name: Add Book To Library
  type: http
  seq: 3
}

post {
  url: {{libraryBaseUrl}}/api/v1/library
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Accept: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "bookId": "{{bookId}}",
    "wishlist": false
  }
}

script:post-response {
  const raw = res.getBody();
  let data = {};
  if (typeof raw === "string" && raw.length) data = JSON.parse(raw);
  else if (raw && raw.parsedBody) data = raw.parsedBody;
  else if (raw) data = raw;
  if (data.userBookId) bru.setEnvVar("userBookId", data.userBookId);
}
