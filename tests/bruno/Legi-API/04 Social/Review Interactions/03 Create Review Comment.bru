meta {
  name: Create Review Comment
  type: http
  seq: 3
}

post {
  url: {{socialBaseUrl}}/api/v1/social/reviews/{{reviewId}}/comments
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Accept: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "content": "Review comment created from Bruno."
  }
}

docs {
  Comments on a review (InteractableType.Review). Saves {{commentId}} so the
  cross-type "Comments/Delete Comment" request can target it.
}

script:post-response {
  const raw = res.getBody();
  let data = {};
  if (typeof raw === "string" && raw.length) data = JSON.parse(raw);
  else if (raw && raw.parsedBody) data = raw.parsedBody;
  else if (raw) data = raw;
  if (data.commentId) bru.setEnvVar("commentId", data.commentId);
}
