meta {
  name: Search Books By Tag
  type: http
  seq: 3
}

get {
  url: {{catalogBaseUrl}}/api/v1/catalog/books
  body: none
  auth: none
}

headers {
  Accept: application/json
}

query {
  tagSlug: {{tagSlug}}
  minRating: 3.5
  pageNumber: 1
  pageSize: 20
  sortBy: AverageRating
  sortDescending: true
}
