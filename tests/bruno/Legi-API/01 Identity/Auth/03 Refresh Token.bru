meta {
  name: Refresh Token
  type: http
  seq: 3
}

post {
  url: {{identityBaseUrl}}/api/v1/identity/auth/refresh
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "refreshToken": "{{refreshToken}}"
  }
}

script:post-response {
  const raw = res.getBody();
  let data = {};
  if (typeof raw === "string" && raw.length) data = JSON.parse(raw);
  else if (raw && raw.parsedBody) data = raw.parsedBody;
  else if (raw) data = raw;
  if (data.token) bru.setEnvVar("accessToken", data.token);
  if (data.refreshToken) bru.setEnvVar("refreshToken", data.refreshToken);
}
