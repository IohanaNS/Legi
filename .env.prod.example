# =============================================================================
# BukiHub PRODUCTION environment template.
#
# This file holds only NON-SECRET, structural configuration (hostnames, DB/bucket
# names, URLs, toggles, build-time public keys). Every actual SECRET — JWT keys,
# MFA key, DB/RabbitMQ/MinIO passwords, connection strings, Turnstile & SMTP
# secrets — lives in ./secrets as a Docker secret file, NOT here. See §6 of
# Docs/DEPLOYMENT-hardening.md.
#
#   cp .env.prod.example .env.prod && $EDITOR .env.prod   # fill the values below
#   ./scripts/gen-prod-secrets.sh                          # generates ./secrets
#   ./db/tls/gen-db-certs.sh                                # Postgres TLS cert
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
# .env.prod and ./secrets are gitignored. NEVER commit either.
# =============================================================================

# ---- JWT (RS256 asymmetric keys) --------------------------------------------
# The keypair itself is generated into ./secrets (Jwt__PublicKey / Jwt__PrivateKey)
# by gen-prod-secrets.sh. Only the non-secret claims live here.
Jwt__Issuer=BukiHub
Jwt__Audience=BukiHub
# Short access-token lifetime limits the window of a stolen token (no revocation list yet).
Jwt__AccessTokenExpirationMinutes=15
Jwt__RefreshTokenExpirationDays=7

# ---- Databases — names & roles (passwords are in ./secrets) -----------------
# Each DB has TWO roles (least privilege):
#   *_DB_ADMIN_USER  bootstrap superuser — creates the app role on first init only;
#                    the application never connects with it.
#   *_DB_USER        non-superuser role the API uses at runtime (owns its schema, so
#                    migrations work; cannot reach other DBs, create roles, or run
#                    COPY ... PROGRAM).
# The matching passwords (*_db_admin_password / *_db_app_password) and the API
# connection strings (ConnectionStrings__*) are generated into ./secrets.
IDENTITY_DB_ADMIN_USER=legi_identity_admin
IDENTITY_DB_USER=legi_identity_app
IDENTITY_DB_NAME=legi_identity

CATALOG_DB_ADMIN_USER=legi_catalog_admin
CATALOG_DB_USER=legi_catalog_app
CATALOG_DB_NAME=legi_catalog

LIBRARY_DB_ADMIN_USER=legi_library_admin
LIBRARY_DB_USER=legi_library_app
LIBRARY_DB_NAME=legi_library

SOCIAL_DB_ADMIN_USER=legi_social_admin
SOCIAL_DB_USER=legi_social_app
SOCIAL_DB_NAME=legi_social

# ---- RabbitMQ ----------------------------------------------------------------
# Password is in ./secrets/RabbitMq__Password.
RabbitMq__Username=legi

# ---- Object storage (MinIO) --------------------------------------------------
# Access/secret keys are in ./secrets (Storage__AccessKey / Storage__SecretKey).
Storage__Bucket=legi-media
Storage__CoversBucket=legi-covers

# ---- Cloudflare Turnstile (bot protection) ----------------------------------
# The SERVER secret is in ./secrets/Turnstile__SecretKey. The SITE key below is
# public (baked into the frontend bundle at build time).
# Set Turnstile__Enabled=false ONLY to disable (not advised in prod).
Turnstile__Enabled=true
Turnstile__AllowedHostnames__0=yourdomain.com
VITE_TURNSTILE_SITE_KEY=CHANGE_ME_turnstile_site_key

# ---- Google sign-in (optional — leave blank to disable) ---------------------
# The client id is public (not a secret); blank disables Google sign-in.
GoogleAuth__ClientId=
VITE_GOOGLE_CLIENT_ID=

# ---- Password reset / email links -------------------------------------------
PasswordReset__FrontendBaseUrl=https://yourdomain.com
PasswordReset__TokenLifetimeMinutes=60
EmailConfirmation__FrontendBaseUrl=https://yourdomain.com
EmailConfirmation__TokenLifetimeMinutes=1440

# ---- SMTP (transactional email — required in production) --------------------
# The password is in ./secrets/Smtp__Password. Configure SPF/DKIM/DMARC on the
# sending domain.
Smtp__Host=smtp.yourprovider.com
Smtp__Port=587
Smtp__Username=CHANGE_ME_smtp_username
Smtp__FromAddress=no-reply@yourdomain.com
Smtp__FromName=BukiHub
Smtp__UseStartTls=true

# ---- External catalog enrichment (optional) ---------------------------------
ExternalServices__GoogleBooks__Enabled=true
ExternalServices__GoogleBooks__ApiKey=

# ---- Web tier --------------------------------------------------------------
# The web container is published ONLY on loopback. Front it with a host TLS
# reverse proxy (Caddy/Traefik/nginx) terminating HTTPS for yourdomain.com.
WEB_HTTP_PORT=8080
