# =============================================================================
# BukiHub PRODUCTION environment template.
#
#   cp .env.prod.example .env.prod
#   # fill EVERY value below — the stack refuses to start with a missing secret
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
# .env.prod is gitignored. NEVER commit real secrets. Prefer a real secrets
# manager (Docker secrets / Vault / cloud KMS) over a file on disk once you can.
# Generate each secret independently, e.g.:  openssl rand -base64 48
# =============================================================================

# ---- JWT (shared across services) -------------------------------------------
# Min 32 bytes. Use a long random value; rotate on suspicion of compromise.
Jwt__Secret=CHANGE_ME_min_32_bytes_random_secret_xxxxxxxxxxxxxxxx
Jwt__Issuer=BukiHub
Jwt__Audience=BukiHub
# Short access-token lifetime limits the window of a stolen token (no revocation list yet).
Jwt__AccessTokenExpirationMinutes=15
Jwt__RefreshTokenExpirationDays=7

# ---- Databases — one STRONG, UNIQUE password each ---------------------------
IDENTITY_DB_USER=legi_identity
IDENTITY_DB_PASSWORD=CHANGE_ME_identity_db_password
IDENTITY_DB_NAME=legi_identity

CATALOG_DB_USER=legi_catalog
CATALOG_DB_PASSWORD=CHANGE_ME_catalog_db_password
CATALOG_DB_NAME=legi_catalog

LIBRARY_DB_USER=legi_library
LIBRARY_DB_PASSWORD=CHANGE_ME_library_db_password
LIBRARY_DB_NAME=legi_library

SOCIAL_DB_USER=legi_social
SOCIAL_DB_PASSWORD=CHANGE_ME_social_db_password
SOCIAL_DB_NAME=legi_social

# ---- RabbitMQ ----------------------------------------------------------------
RabbitMq__Username=legi
RabbitMq__Password=CHANGE_ME_rabbitmq_password

# ---- Object storage (MinIO) --------------------------------------------------
Storage__AccessKey=CHANGE_ME_minio_access_key
Storage__SecretKey=CHANGE_ME_minio_secret_key
Storage__Bucket=legi-media
Storage__CoversBucket=legi-covers

# ---- Cloudflare Turnstile (bot protection) ----------------------------------
# Required when enabled. Set Turnstile__Enabled=false ONLY to disable (not advised in prod).
Turnstile__Enabled=true
Turnstile__SecretKey=CHANGE_ME_turnstile_secret_key
Turnstile__AllowedHostnames__0=yourdomain.com
VITE_TURNSTILE_SITE_KEY=CHANGE_ME_turnstile_site_key

# ---- Google sign-in (optional — leave blank to disable) ---------------------
GoogleAuth__ClientId=
VITE_GOOGLE_CLIENT_ID=

# ---- Password reset / email links -------------------------------------------
PasswordReset__FrontendBaseUrl=https://yourdomain.com
PasswordReset__TokenLifetimeMinutes=60

# ---- SMTP (transactional email — required in production) --------------------
# Configure SPF/DKIM/DMARC on the sending domain.
Smtp__Host=smtp.yourprovider.com
Smtp__Port=587
Smtp__Username=CHANGE_ME_smtp_username
Smtp__Password=CHANGE_ME_smtp_password
Smtp__FromAddress=no-reply@yourdomain.com
Smtp__FromName=BukiHub
Smtp__UseStartTls=true

# ---- External catalog enrichment (optional) ---------------------------------
ExternalServices__GoogleBooks__Enabled=true
ExternalServices__GoogleBooks__ApiKey=

# ---- Web tier --------------------------------------------------------------
# The web container is published ONLY on loopback. Front it with a host TLS
# reverse proxy (Caddy/Traefik/nginx) terminating HTTPS for yourdomain.com.
WEB_HTTP_PORT=8080
